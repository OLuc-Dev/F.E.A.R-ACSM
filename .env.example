# F.E.A.R. runtime configuration
# Copy this file to .env and fill in your real values locally.
# Never commit .env to GitHub.

FEAR_HOST=127.0.0.1
FEAR_PORT=8765
FEAR_ASSISTANT_NAME=F.E.A.R.

# Local Whisper model: tiny, base, small, medium, large
WHISPER_MODEL=base

# Optional audio inputs (off by default; both require a microphone).
FEAR_ENABLE_VOICE_LISTENER=0
FEAR_ENABLE_CLAP_DETECTOR=0

# Audio
FEAR_SAMPLE_RATE=16000
FEAR_CHUNK_SIZE=1024
CLAP_THRESHOLD=0.1

# Comma-separated origins allowed to call the API (the Next.js dev server).
FEAR_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend: base URL the Next.js app uses to reach this backend.
NEXT_PUBLIC_FEAR_API_BASE=http://127.0.0.1:8765

# Conversation
# Path to F.E.A.R.'s persona prompt (Markdown/text). Edit prompts/fear_persona.md
# to change his voice. Leave empty to use the built-in fallback persona.
FEAR_PERSONA_FILE=prompts/fear_persona.md
# Default persona mode (the Configuração panel can switch it live per session):
#   equilibrio = frio, lúcido e leal (padrão)
#   sombrio    = mais cortante, mais niilista, mais Ultron
#   cirurgico  = sem teatro, diagnóstico e ação
FEAR_PERSONA_MODE=equilibrio
# How many recent messages (user + assistant) to keep in the rolling dialogue
# window sent to the model, so F.E.A.R. follows the conversation across turns.
FEAR_MAX_HISTORY_TURNS=12

# ChromaDB persistent memory
CHROMA_PATH=data/chroma
CHROMA_COLLECTION=fear_memory

# Deployment environment: local | development | test | production.
# In production the app REFUSES to boot without FEAR_SECRET_KEY (see below).
FEAR_ENV=local

# Multi-user accounts (sign-in). FEAR_SECRET_KEY signs session tokens and
# encrypts each user's stored OpenRouter key — set a long random value and keep
# it private. Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
# Leaving it empty works for local dev but resets all logins/keys on restart;
# with FEAR_ENV=production an empty value is fatal at boot (on purpose).
FEAR_SECRET_KEY=
FEAR_USERS_DB=data/users.db
FEAR_SESSION_MAX_AGE_DAYS=30
# Closed sign-up: if set, /auth/register requires this code (share it with your
# friends). Leave empty for open registration.
FEAR_INVITE_CODE=

# OpenRouter — get a key at https://openrouter.ai/keys, pick a model at
# https://openrouter.ai/models. With a key + model set, F.E.A.R. gives full replies.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Default is the free GPT-OSS 120B; change to any model available in your account.
OPENROUTER_CHAT_MODEL=openai/gpt-oss-120b:free
OPENROUTER_EMBEDDING_MODEL=
OPENROUTER_HTTP_REFERER=http://127.0.0.1:8765
OPENROUTER_APP_TITLE=F.E.A.R.

# Spotify — create an app at https://developer.spotify.com/dashboard, add the
# redirect URI below to the app settings, then run a one-time browser auth:
#   python scripts/spotify_login.py
SPOTIPY_CLIENT_ID=
SPOTIPY_CLIENT_SECRET=
SPOTIPY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Google Calendar (read-only) — create a project at https://console.cloud.google.com,
# enable the Calendar API, make an OAuth "Desktop" client, download it as
# credentials.json, then run a one-time browser auth:
#   python scripts/google_login.py
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=data/google_token.json
GOOGLE_CALENDAR_ID=primary
