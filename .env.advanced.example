# Optional advanced F.E.A.R. features
# Copy values into your local .env when needed. Never commit real secrets.

# Natural TTS provider. If empty, F.E.A.R. falls back to pyttsx3 offline.
ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Obsidian vault indexing
OBSIDIAN_VAULT_PATH=
OBSIDIAN_SPEAKER=fear_user

# Local markdown book-summary library
BOOK_KNOWLEDGE_PATH=data/book_summaries
BOOK_KNOWLEDGE_COLLECTION=book_knowledge

# OpenRouter model examples. Pick later from the free/available models in your account.
OPENROUTER_CHAT_MODEL=
OPENROUTER_EMBEDDING_MODEL=
